# Ignore everything by default; this repo is a lightweight review package.
*

# Root files
!.gitignore
!README.md

# Current docs
!docs/
docs/*
!docs/README.md
!docs/00_current/
docs/00_current/*
!docs/00_current/*.md

# Core scripts
!scripts/
scripts/*
!scripts/*.py

# Dictionary inputs for Panel D-style validation
!data/
data/*
!data/dictionaries/
data/dictionaries/*
!data/dictionaries/*.csv
!data/dictionaries/*.json

# Review result bundles
!results/
results/*
